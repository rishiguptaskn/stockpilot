# StockPilot API — environment variables
# Copy to .env (gitignored) and fill in. The API key lives ONLY here (server-side);
# it is never exposed to the browser or the Next.js client bundle.

# --- AI agent layer (required for /agents/*) --------------------------------
ANTHROPIC_API_KEY=

# Optional model/cost tuning (defaults shown):
#   Sub-agents run on Sonnet; Master synthesis runs on Opus.
#   Set SONNET_ONLY=1 to run everything on Sonnet (~half the cost).
# STOCKPILOT_SONNET_ONLY=0
# STOCKPILOT_SUB_AGENT_MODEL=claude-sonnet-5
# STOCKPILOT_MASTER_MODEL=claude-opus-4-8
# STOCKPILOT_MAX_TOOL_ITERS=8
# STOCKPILOT_MAX_RUN_TOKENS=60000

# --- Supabase (shared with the web app) -------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Needed only to persist agent_runs / ingest prices (bypasses RLS). Optional for
# local dev — without it, agent runs simply aren't written to the audit table.
SUPABASE_SERVICE_ROLE_KEY=

# --- Auth (optional) --------------------------------------------------------
# When set, /agents/* verifies the Supabase JWT and attributes runs to the user.
# SUPABASE_JWT_SECRET=
# Set to 1 to REQUIRE a valid token on /agents/* (default: allow anonymous).
# STOCKPILOT_REQUIRE_AUTH=0
